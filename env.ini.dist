# AUXO MCP Server Configuration
# Copy this file to env.ini or export these variables in your shell.

# AUXO API endpoint (default: api.on2it.net)
# AUXO_API_URL=api.on2it.net

# Zero Trust API token — enables protect surfaces, locations, states, measures, etc.
AUXO_ZT_TOKEN=

# Tickets/Case Management API token — enables case/ticket management tools.
AUXO_TICKET_TOKEN=

# Server mode: STDIO (default) or HTTP
# AUXO_SERVER_MODE=STDIO

# Port for HTTP mode (default: 8080)
# AUXO_SERVER_PORT=8080

# Explicitly enable/disable domains (auto-detected from tokens by default)
# AUXO_ENABLE_ZERO_TRUST=true
# AUXO_ENABLE_TICKETS=true

# Enable debug logging for API calls (default: false)
# AUXO_DEBUG=false
